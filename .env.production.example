APP_NAME="SFPA Voting"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Riyadh
APP_URL=https://your-domain.sa

APP_LOCALE=ar
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

# Use 12+ in production. Higher = slower but harder to brute force hashes.
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
# Only warnings and above in production — debug logs leak PII and structure.
LOG_LEVEL=warning

# Use MySQL / PostgreSQL in production, not SQLite.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sfpa_voting
DB_USERNAME=sfpa
DB_PASSWORD=

# Encrypt session payload at rest — recommended for admin panels.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=sfpa

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="no-reply@your-domain.sa"
MAIL_FROM_NAME="${APP_NAME}"

# --- After deploy checklist ---
# 1. php artisan key:generate
# 2. php artisan migrate --force
# 3. php artisan config:cache route:cache view:cache
# 4. chown -R www-data:www-data storage bootstrap/cache
# 5. set APP_DEBUG=false (double-check)
# 6. serve behind HTTPS only (redirect 80 -> 443)
